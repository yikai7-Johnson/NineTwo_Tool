<view class="main">
  <view class="title-wrap">
    <image class="title-icon" mode="aspectFit" src="/assets/NineTwoToolboxLogo.png" aria-label="NineTwoToolbox Logo" />
  </view>
  <view class="desc"> NineTwoToolbox 玖贰工具箱 </view>
  <pull-down-list
    wx:for="{{list}}"
    name="{{item.name}}"
    icon="{{item.icon}}"
    wx:key="name"
    childArr="{{item.childArr}}"
    bind:click="clickHandle"
  />
</view>
